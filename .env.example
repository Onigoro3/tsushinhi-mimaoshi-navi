# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env自体はGitにコミットしないでください(.gitignoreで除外済み)。
#
#   cp .env.example .env   (Windowsの場合は copy .env.example .env)

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=
# 記事生成モデル。社長の希望により品質優先でSonnet 5を使用。
CLAUDE_MODEL=claude-sonnet-5

# --- はてなブログ (AtomPub API) ---
# ブログ名「海外SIM・eSIM比較ガイド」に改名(2026-07-13社長最終決定、通信費比較からeSIM比較へ
# 全面ピボット、ceo/tasks.md参照)。ドメインは既存のはてなアカウント(MagicaiDemon)の
# サブドメインをそのまま使用する方針(Dragon「型落ち家電ラボ」もURLがmagicaidrop.hatenablog.com
# とブランド名不一致の前例あり)。ブログの「タイトル」を管理画面で
# 「海外SIM・eSIM比較ガイド」に設定すればよく、ドメイン変更は不要。
HATENA_ID=MagicaiDemon
HATENA_BLOG_DOMAIN=magicaidemon.hatenablog.com
HATENA_API_KEY=
# ↑ demon/MagicaiDemon.txt に記載のAtomPub APIキーを設定してください。

# --- アフィリエイト(バリューコマース) ---
# トリファ・airalo・Saily 3社と即時提携済み(demon/Simmemo_valuecommerce_pid.txt参照)。
# sid・pidはblog_auto_post/affiliate.pyにハードコードしているため、環境変数の設定は不要。

# --- ドライラン(動作確認用、任意) ---
# true/1/yes を設定すると、はてなブログへの実際の投稿(post_entry())を行わず、
# 投稿予定のタイトル・本文冒頭・比較表HTML等を標準出力するだけで停止する。
# 本番投稿する場合はコメントアウトまたは空にしておくこと。
# DEMON_DRY_RUN=true
